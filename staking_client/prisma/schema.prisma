generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Alert {
  id        BigInt   @id @default(autoincrement())
  alertType String
  severity  String   @default("info")
  message   String
  metadata  Json?
  processed Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([alertType])
  @@index([createdAt])
  @@index([processed])
  @@index([severity])
}

model AlertQueue {
  id          BigInt   @id @default(autoincrement())
  alertId     BigInt?  @unique
  alertType   String
  payload     Json?
  status      String   @default("pending")
  retryCount  Int      @default(0)
  historical  Boolean  @default(false)
  lastError   String?
  availableAt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime

  @@index([alertType])
  @@index([status, availableAt])
}

model IndexerCursor {
  id                     Int      @id @default(autoincrement())
  lastProcessedSlot      BigInt   @default(0)
  lastProcessedSignature String?
  lastProcessedIxIndex   Int?
  updatedAt              DateTime
  jobName                String   @unique @default("default")
}

model Pool {
  id              String   @id
  authority       String
  tokenMint       String
  vaultBump       Int
  stakedAmount    BigInt   @default(0)
  rewardAmount    BigInt   @default(0)
  rewardPerShare  BigInt   @default(0)
  totalShares     BigInt   @default(0)
  lockUpPeriod    BigInt
  startTime       BigInt
  endTime         BigInt?
  lastUpdatedSlot BigInt
  createdAt       DateTime @default(now())
  updatedAt       DateTime
  createdTxHash   String?  @db.VarChar(88)
  description     String   @default("")
  name            String   @default("")
  poolId          Int?
  rewardMint      String   @default("")

  @@index([authority])
  @@index([lastUpdatedSlot])
  @@index([poolId])
}

model ProcessedSignature {
  id        Int      @id @default(autoincrement())
  signature String   @unique @db.VarChar(88)
  slot      BigInt
  status    String   @default("processing")
  createdAt DateTime @default(now())
  updatedAt DateTime

  @@index([slot])
  @@index([status, updatedAt])
}

model SlotProgress {
  slot        BigInt   @id
  firstSeenAt DateTime @default(now())
  processed   Boolean  @default(false)
  source      String

  @@index([firstSeenAt])
  @@index([processed])
}

model Stakingpool {
  id              String   @id
  poolId          Int?
  authority       String
  tokenMint       String
  rewardMint      String   @default("")
  vaultBump       Int
  stakedAmount    BigInt   @default(0)
  rewardAmount    BigInt   @default(0)
  rewardPerShare  BigInt   @default(0)
  totalShares     BigInt   @default(0)
  lockUpPeriod    BigInt
  startTime       BigInt
  endTime         BigInt?
  lastUpdatedSlot BigInt
  createdAt       DateTime @default(now())
  updatedAt       DateTime

  @@index([authority])
  @@index([lastUpdatedSlot])
}

model TxActivity {
  id            BigInt    @id @default(autoincrement())
  signature     String    @db.VarChar(88)
  slot          BigInt
  blockTime     DateTime?
  ixIndex       Int
  eventVersion  Int       @default(1)
  eventType     String
  userAuthority String?
  poolId        String?
  shares        BigInt?
  amount        BigInt?
  timestamp     BigInt?
  status        String    @default("confirmed")
  historical    Boolean   @default(false)
  metadata      Json?
  createdAt     DateTime  @default(now())

  @@unique([signature, ixIndex])
  @@index([blockTime])
  @@index([eventType])
  @@index([eventVersion])
  @@index([historical])
  @@index([poolId])
  @@index([slot])
  @@index([status])
  @@index([userAuthority])
}

model TxQueue {
  id         BigInt   @id @default(autoincrement())
  signature  String   @unique @db.VarChar(88)
  slot       BigInt
  rawTx      Json
  retryCount Int      @default(0)
  status     String   @default("pending")
  error      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime

  @@index([slot])
  @@index([status])
}

model UserPosition {
  id              String   @id
  pool            String
  userAuthority   String
  shares          BigInt
  unlockedShares  BigInt   @default(0)
  depositAmount   BigInt
  depositTime     BigInt
  rewardDebt      BigInt   @default(0)
  lastUpdatedSlot BigInt
  createdAt       DateTime @default(now())
  updatedAt       DateTime

  @@index([lastUpdatedSlot])
  @@index([pool])
  @@index([userAuthority])
}

model VaultHistory {
  id              BigInt   @id @default(autoincrement())
  poolId          String
  slot            BigInt
  expectedBalance BigInt
  actualBalance   BigInt
  difference      BigInt
  reconciled      Boolean  @default(false)
  tolerance       BigInt
  createdAt       DateTime @default(now())
  vaultType       String   @default("stake")

  @@index([poolId])
  @@index([reconciled])
  @@index([slot])
}
