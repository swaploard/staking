# Database
DATABASE_URL=postgresql://user:password@localhost:5432/staking_indexer

# RPC Endpoints (primary and fallback)
RPC_ENDPOINT=http://localhost:8899
RPC_ENDPOINT_FALLBACK=http://localhost:8900

# Solana Program
STAKING_PROGRAM_ID=7TjUWKKLqxQVxSWqVFN9PqpNFe8Q8RhXFDx3CGrQZsm

# Indexer Config
WEBSOCKET_ENDPOINT=ws://localhost:8900
NETWORK=localnet

# Processing
CONFIRMED_STATUS_ONLY=true
MAX_CONCURRENT_TX_WORKERS=5
PROCESSING_TIMEOUT_MS=60000
STALE_PROCESSING_THRESHOLD_MS=120000

# Logging
LOG_LEVEL=info
